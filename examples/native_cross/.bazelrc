test --test_output=errors

# Required by toolchains_llvm_bootstrapped
build --experimental_cc_static_library

# Cross-compilation configurations
build:linux_x86_64 --platforms=//:linux_x86_64
build:linux_aarch64 --platforms=//:linux_aarch64
build:darwin_aarch64 --platforms=//:darwin_aarch64

try-import %workspace%/user.bazelrc
